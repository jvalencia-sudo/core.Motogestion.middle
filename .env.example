# ──────────────────────────────────────────────────────────────
# Variables del FRONT (Next.js). En local van en .env (gitignored).
# En PRODUCCIÓN se configuran en Vercel → Project Settings → Environment Variables.
# Los valores de secretos cópialos de tu .env local.
# ──────────────────────────────────────────────────────────────

# URL pública del front. EN PRODUCCIÓN DEBE SER https (Auth0 lo exige).
# = la URL que te da Vercel (https://<tu-proyecto>.vercel.app) o tu dominio.
APP_BASE_URL=http://localhost:3000
AUTH0_BASE_URL=http://localhost:3000   # mismo valor que APP_BASE_URL (resto v3)

# Auth0 (mismos valores del tenant que uses; por ahora el de dev)
AUTH0_DOMAIN=dev-q4srpexn6ajjjfqs.us.auth0.com
AUTH0_ISSUER_BASE_URL=https://dev-q4srpexn6ajjjfqs.us.auth0.com
AUTH0_CLIENT_ID=__copiar_de_tu_.env__
AUTH0_CLIENT_SECRET=__copiar_de_tu_.env__
AUTH0_SECRET=__copiar_de_tu_.env__       # clave de cifrado de cookies
AUTH0_AUDIENCE=https://moto.com/api
AUTH0_SCOPE=openid profile email read:users write:users read:orders write:orders

# Backend (API en producción, en el VPS)
BASE_API_URL=https://api.motogestion.miclickderecho.com/api
NEXT_PUBLIC_API_URL=https://api.motogestion.miclickderecho.com
